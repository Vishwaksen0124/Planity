# Server Configuration
PORT=8800
NODE_ENV=production

# Database Configuration - MongoDB Atlas
# Get your connection string from: MongoDB Atlas Dashboard -> Connect -> Connect your application
# Replace <username>, <password>, and <cluster-url> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/planity?retryWrites=true&w=majority

# JWT Secret (Generate a secure random string for production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Redis Configuration (Optional - for caching)
# For Render: Use Redis add-on or Upstash Redis
# Leave empty to run without caching (app will still work)
REDIS_URL=redis://default:password@redis-server-url:6379

# CORS Origins (comma-separated for multiple origins)
# Add your Render frontend URL here
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend.onrender.com
